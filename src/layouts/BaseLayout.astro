---
/**
 * BaseLayout — the shell every page inherits.
 *
 * Responsibilities:
 *  - Load the global stylesheet + fonts once.
 *  - Render <head> SEO/meta via the SEO component.
 *  - Enable animated, accessible page transitions (<ClientRouter/>).
 *  - Provide semantic landmarks: skip-link → header → main → footer.
 *
 * Page-specific SEO is passed straight through to <SEO/>.
 */
import '@styles/global.css';
import { ClientRouter } from 'astro:transitions';
import SEO from '@components/seo/SEO.astro';
import JsonLd from '@components/seo/JsonLd.astro';
import Header from '@components/layout/Header.astro';
import Footer from '@components/layout/Footer.astro';
import { site } from '@lib/settings';
import { personSchema, websiteSchema, resolveImageUrl } from '@lib/seo';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  path?: string;
  type?: 'website' | 'article' | 'profile' | 'music.album';
  noindex?: boolean;
  publishedTime?: string;
  modifiedTime?: string;
  /** Additional schema.org nodes for this page (album, event, article, …). */
  schemas?: Record<string, unknown>[];
  /** Extra class on <main>, e.g. for full-bleed pages. */
  mainClass?: string;
}

const { mainClass, schemas = [], ...seo } = Astro.props;
const lang = site.locale.replace('_', '-');

// Sitewide identity graph is present on every page; pages append their own.
const personImage = await resolveImageUrl(site.logo ?? site.defaultOgImage);
const graph = [websiteSchema(), personSchema(personImage), ...schemas];
---

<!doctype html>
<html lang={lang}>
  <head>
    {/* Mark JS available ASAP so reveal styles only hide content when we can reveal it. */}
    <script is:inline>
      document.documentElement.classList.add('js');
    </script>
    <SEO {...seo} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <JsonLd graph={graph} />
    <ClientRouter />
  </head>
  <body>
    <a href="#main" class="skip-link">Skip to content</a>
    <Header />
    <main id="main" class={mainClass}>
      <slot />
    </main>
    <Footer />

    <script>
      // Scroll-reveal: fade/rise elements as they enter the viewport. Skipped
      // entirely for users who prefer reduced motion. Re-initialised after each
      // view transition so freshly-swapped content animates too.
      function setupReveal() {
        const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
        const els = Array.from(document.querySelectorAll<HTMLElement>('[data-reveal]:not(.is-inview)'));
        if (reduced || !('IntersectionObserver' in window)) {
          els.forEach((el) => el.classList.add('is-inview'));
          return;
        }
        const io = new IntersectionObserver(
          (entries, obs) => {
            for (const entry of entries) {
              if (!entry.isIntersecting) continue;
              entry.target.classList.add('is-inview');
              obs.unobserve(entry.target);
            }
          },
          { rootMargin: '0px 0px -8% 0px', threshold: 0.1 }
        );
        for (const el of els) {
          // Gentle stagger among reveal siblings (grids feel choreographed).
          const parent = el.parentElement;
          if (parent) {
            const sibs = Array.from(parent.children).filter((c) => c.hasAttribute('data-reveal'));
            const idx = sibs.indexOf(el);
            if (idx > 0) el.style.setProperty('--reveal-delay', `${Math.min(idx, 6) * 55}ms`);
          }
          io.observe(el);
        }
      }
      setupReveal();
      document.addEventListener('astro:after-swap', setupReveal);
    </script>
  </body>
</html>
