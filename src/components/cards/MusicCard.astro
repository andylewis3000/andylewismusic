---
/**
 * MusicCard — a release in the discography grid. Links to the detail page.
 * The whole card is a single link (no nested interactive elements).
 */
import type { Album } from '@lib/content';
import Image from '@components/media/Image.astro';
import { year } from '@lib/format';

interface Props {
  album: Album;
}
const { album } = Astro.props;
const { title, type, releaseDate, cover, coverAlt } = album.data;
const typeLabel = type === 'ep' ? 'EP' : type.charAt(0).toUpperCase() + type.slice(1);
---

<a class="card music-card" href={`/music/${album.id}/`} data-reveal>
  <div class="music-cover">
    <Image
      path={cover}
      alt={coverAlt}
      aspect="1/1"
      sizes="(max-width: 640px) 90vw, (max-width: 1024px) 45vw, 300px"
      placeholderLabel={title}
    />
  </div>
  <div class="music-meta">
    <span class="kicker">{typeLabel} · {year(releaseDate)}</span>
    <h3 class="music-title">{title}</h3>
  </div>
</a>

<style>
  .music-card {
    display: block;
  }
  .music-cover :global(img),
  .music-cover :global(.media-placeholder) {
    width: 100%;
    object-fit: cover;
    transition: transform var(--dur-slow) var(--ease-out);
  }
  .music-card:hover .music-cover :global(img) {
    transform: scale(1.04);
  }
  .music-meta {
    padding: 1rem 1.15rem 1.2rem;
    display: grid;
    gap: 0.5rem;
  }
  .music-title {
    font-size: var(--text-h4);
  }
</style>
