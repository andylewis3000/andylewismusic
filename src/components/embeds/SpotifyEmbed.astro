---
/**
 * SpotifyEmbed — a click-to-load Spotify facade. Ships no third-party iframe
 * (and sets no third-party cookies) until the user chooses to load the player.
 * A single delegated listener handles every streaming facade on the page.
 */
import Icon from '@components/ui/Icon.astro';

interface Props {
  url: string;
  title?: string;
  compact?: boolean;
}
const { url, title = 'Spotify player', compact = false } = Astro.props;

// https://open.spotify.com/album/ID → https://open.spotify.com/embed/album/ID
const match = url.match(/open\.spotify\.com\/(album|track|playlist|artist)\/([A-Za-z0-9]+)/);
const embedUrl = match ? `https://open.spotify.com/embed/${match[1]}/${match[2]}?theme=0` : null;
const height = compact ? 152 : match?.[1] === 'track' ? 152 : 352;
---

{
  embedUrl && (
    <button
      class="embed-facade spotify"
      type="button"
      data-embed-src={embedUrl}
      data-embed-title={title}
      data-embed-height={height}
      aria-label={`Load the Spotify player for ${title}`}
    >
      <span class="embed-badge">
        <Icon name="spotify" size={26} />
      </span>
      <span class="embed-text">
        <strong>Play on Spotify</strong>
        <small>Loads the Spotify player</small>
      </span>
    </button>
  )
}

<script>
  // Shared across all streaming facades (Spotify + Apple Music). Bound once.
  if (!(window as any).__embedFacadeBound) {
    (window as any).__embedFacadeBound = true;
    document.addEventListener('click', (e) => {
      const btn = (e.target as HTMLElement).closest<HTMLButtonElement>(
        '.embed-facade[data-embed-src]'
      );
      if (!btn || btn.dataset.loaded) return;
      const iframe = document.createElement('iframe');
      iframe.src = btn.dataset.embedSrc!;
      iframe.title = btn.dataset.embedTitle || 'Player';
      iframe.loading = 'lazy';
      iframe.style.width = '100%';
      iframe.style.height = `${btn.dataset.embedHeight || 352}px`;
      iframe.style.border = '0';
      iframe.style.borderRadius = '12px';
      iframe.allow = 'autoplay; clipboard-write; encrypted-media; fullscreen; picture-in-picture';
      iframe.setAttribute('allowfullscreen', '');
      btn.dataset.loaded = '1';
      btn.replaceWith(iframe);
    });
  }
</script>

<style>
  .embed-facade {
    display: flex;
    align-items: center;
    gap: 1rem;
    width: 100%;
    padding: 1.25rem 1.4rem;
    text-align: left;
    background: linear-gradient(180deg, var(--color-surface), var(--color-bg-elevated));
    border: 1px solid var(--color-line);
    border-radius: var(--radius-lg);
    cursor: pointer;
    color: var(--color-ink);
    transition:
      border-color var(--dur-base) var(--ease-standard),
      transform var(--dur-fast) var(--ease-out);
  }
  .embed-facade:hover {
    border-color: var(--color-line-strong);
    transform: translateY(-2px);
  }
  .embed-badge {
    display: grid;
    place-items: center;
    width: 3rem;
    height: 3rem;
    flex: none;
    border-radius: 999px;
    background: var(--color-accent-soft);
    color: var(--color-accent);
  }
  .embed-text {
    display: grid;
    gap: 0.15rem;
  }
  .embed-text strong {
    font-weight: 600;
  }
  .embed-text small {
    color: var(--color-ink-muted);
    font-size: var(--text-caption);
  }
</style>
