---
/**
 * About equipment block — equipment highlight groups (from about.md).
 */
import Section from '@components/layout/Section.astro';
import { getAbout } from '@lib/content';
import type { BlockProps } from '@lib/blocks';

const {
  heading = 'Equipment',
  tone = 'white',
  backgroundImage,
  backgroundAlt,
  parallax = false,
} = Astro.props as BlockProps;
const about = await getAbout();
const equipment = about?.data.equipment ?? [];
---

{
  equipment.length > 0 && (
    <Section
      tone={tone}
      backgroundImage={backgroundImage}
      backgroundAlt={backgroundAlt}
      parallax={parallax}
      padding="tight"
      innerClass="two-col"
    >
      <h2 class="col-title">{heading}</h2>
      <div class="equip-groups">
        {equipment.map((group) => (
          <div class="equip-group">
            <h3 class="equip-label">{group.label}</h3>
            <ul>
              {group.items.map((item) => (
                <li>{item}</li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </Section>
  )
}

<style>
  .two-col {
    display: grid;
    gap: 1.5rem;
  }
  @media (min-width: 820px) {
    .two-col {
      grid-template-columns: 14rem 1fr;
      gap: 3rem;
    }
  }
  .col-title {
    font-size: var(--text-h3);
  }
  .equip-groups {
    display: grid;
    gap: 2rem;
  }
  @media (min-width: 640px) {
    .equip-groups {
      grid-template-columns: repeat(3, 1fr);
    }
  }
  .equip-label {
    font-size: var(--text-caption);
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--color-ink-faint);
    font-family: var(--font-sans);
    font-weight: 600;
    margin-bottom: 0.75rem;
  }
  .equip-group ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 0.5rem;
  }
  .equip-group li {
    color: var(--color-ink-muted);
    font-size: var(--text-small);
    padding-bottom: 0.5rem;
    border-bottom: 1px solid var(--color-line);
  }
</style>
