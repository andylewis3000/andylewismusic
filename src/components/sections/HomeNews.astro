---
import Section from '@components/layout/Section.astro';
import SectionHeader from '@components/ui/SectionHeader.astro';
import BlogCard from '@components/cards/BlogCard.astro';
import { getPosts } from '@lib/content';
import { take, type BlockProps } from '@lib/blocks';

const {
  kicker,
  heading = 'Latest News',
  subheading,
  tone = 'dark',
  backgroundImage,
  backgroundAlt,
  parallax = false,
  limit,
} = Astro.props as BlockProps;
// Prefer featured posts; a limit of 0 shows all (news archive).
const all = await getPosts();
const featured = all.filter((p) => p.data.featured);
const base = limit === 0 ? all : featured.length ? featured : all;
const posts = take(base, limit, 3);
---

{
  posts.length > 0 && (
    <Section tone={tone} backgroundImage={backgroundImage} backgroundAlt={backgroundAlt} parallax={parallax}>
      {
        heading || subheading ? (
          <SectionHeader kicker={kicker} heading={heading} subheading={subheading} href="/blog/" />
        ) : (
          <h2 class="sr-only">News</h2>
        )
      }
      <div class="grid-news">
        {posts.map((post) => (
          <BlogCard post={post} />
        ))}
      </div>
    </Section>
  )
}

<style>
  .grid-news {
    display: grid;
    gap: 1.5rem;
    grid-template-columns: repeat(auto-fill, minmax(min(100%, 300px), 1fr));
  }
</style>
