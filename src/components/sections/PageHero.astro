---
/**
 * PageHero — the standard header for interior pages: kicker, title, intro.
 */
interface Props {
  kicker?: string;
  title: string;
  intro?: string;
  align?: 'start' | 'center';
}
const { kicker, title, intro, align = 'start' } = Astro.props;
---

<header class:list={['page-hero', `align-${align}`]}>
  <div class="container-page">
    {kicker && <span class="kicker">{kicker}</span>}
    <h1 class="page-title">{title}</h1>
    {intro && <p class="page-intro">{intro}</p>}
  </div>
</header>

<style>
  .page-hero {
    padding-block: clamp(3.5rem, 2rem + 7vw, 7rem) clamp(2rem, 1rem + 3vw, 3.5rem);
    border-bottom: 1px solid var(--color-line);
  }
  .page-hero > div {
    display: grid;
    gap: 1.1rem;
  }
  .align-center > div {
    justify-items: center;
    text-align: center;
  }
  .page-title {
    font-size: var(--text-h1);
  }
  .page-intro {
    margin: 0;
    max-width: 60ch;
    font-size: var(--text-lead);
    color: var(--color-ink-muted);
  }
</style>
