---
/**
 * Gear block — equipment grouped by category.
 */
import Section from '@components/layout/Section.astro';
import SectionHeader from '@components/ui/SectionHeader.astro';
import GearCard from '@components/cards/GearCard.astro';
import { getGearByCategory } from '@lib/content';
import type { BlockProps } from '@lib/blocks';

const {
  heading,
  subheading,
  tone = 'dark',
  backgroundImage,
  backgroundAlt,
  parallax = false,
} = Astro.props as BlockProps;
const groups = await getGearByCategory();
---

{
  groups.length > 0 && (
    <Section
      tone={tone}
      backgroundImage={backgroundImage}
      backgroundAlt={backgroundAlt}
      parallax={parallax}
    >
      {(heading || subheading) && <SectionHeader kicker="Setup" heading={heading} subheading={subheading} />}
      {/* Wrapper lives in this component so its scoped grid gap actually applies. */}
      <div class="gear-sections">
        {groups.map((group) => (
          <section class="gear-group" aria-labelledby={`gear-${group.id}`}>
            <h2 id={`gear-${group.id}`} class="gear-heading">
              {group.label}
            </h2>
            <div class="grid-gear">
              {group.items.map((item) => (
                <GearCard item={item} />
              ))}
            </div>
          </section>
        ))}
      </div>
    </Section>
  )
}

<style>
  .gear-sections {
    display: grid;
    gap: 3.5rem;
  }
  .gear-heading {
    font-size: var(--text-h3);
    margin-bottom: 1.5rem;
    padding-bottom: 0.75rem;
    border-bottom: 1px solid var(--color-line);
  }
  .grid-gear {
    display: grid;
    gap: 1.5rem;
    grid-template-columns: repeat(auto-fill, minmax(min(100%, 280px), 1fr));
  }
</style>
