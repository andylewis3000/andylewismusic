---
import Section from '@components/layout/Section.astro';
import SectionHeader from '@components/ui/SectionHeader.astro';
import MusicCard from '@components/cards/MusicCard.astro';
import { getAlbums } from '@lib/content';
import { take, type BlockProps } from '@lib/blocks';

const {
  heading = 'Featured Music',
  subheading,
  tone = 'dark',
  backgroundImage,
  backgroundAlt,
  parallax = false,
  limit,
} = Astro.props as BlockProps;
const featured = (await getAlbums()).filter((a) => a.data.featured);
const albums = take(featured, limit, 3);
---

{
  albums.length > 0 && (
    <Section tone={tone} backgroundImage={backgroundImage} backgroundAlt={backgroundAlt} parallax={parallax}>
      {
        heading || subheading ? (
          <SectionHeader kicker="Discography" heading={heading} subheading={subheading} href="/music/" />
        ) : (
          <h2 class="sr-only">Featured music</h2>
        )
      }
      <div class="grid-cards">
        {albums.map((album) => (
          <MusicCard album={album} />
        ))}
      </div>
    </Section>
  )
}

<style>
  /* auto-fit collapses empty tracks and stretches the actual cards to fill the
     container, so N cards produce N equal, full-width columns (down to the min
     width, then they wrap). No per-count logic needed. */
  .grid-cards {
    display: grid;
    gap: 1.5rem;
    grid-template-columns: repeat(auto-fit, minmax(min(100%, 240px), 1fr));
  }
</style>
