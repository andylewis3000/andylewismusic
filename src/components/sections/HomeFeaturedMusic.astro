---
import Section from '@components/layout/Section.astro';
import SectionHeader from '@components/ui/SectionHeader.astro';
import MusicCard from '@components/cards/MusicCard.astro';
import { getFeaturedAlbums } from '@lib/content';
import type { Tone } from '@lib/pages';

interface Props {
  heading?: string;
  subheading?: string;
  tone?: Tone;
  backgroundImage?: string;
  backgroundAlt?: string;
  parallax?: boolean;
}
const {
  heading = 'Featured Music',
  subheading,
  tone = 'dark',
  backgroundImage,
  backgroundAlt,
  parallax = false,
} = Astro.props;
const albums = await getFeaturedAlbums(3);
---

{
  albums.length > 0 && (
    <Section tone={tone} backgroundImage={backgroundImage} backgroundAlt={backgroundAlt} parallax={parallax}>
      <SectionHeader kicker="Discography" heading={heading} subheading={subheading} href="/music/" />
      <div class="grid-cards">
        {albums.map((album) => (
          <MusicCard album={album} />
        ))}
      </div>
    </Section>
  )
}

<style>
  .grid-cards {
    display: grid;
    gap: 1.5rem;
    grid-template-columns: repeat(auto-fill, minmax(min(100%, 240px), 1fr));
  }
</style>
