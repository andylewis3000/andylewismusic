---
/**
 * About bio block — portrait + Markdown biography (from about.md).
 */
import Section from '@components/layout/Section.astro';
import Image from '@components/media/Image.astro';
import { render } from 'astro:content';
import { getAbout } from '@lib/content';
import type { BlockProps } from '@lib/blocks';

const { tone = 'light', backgroundImage, backgroundAlt, parallax = false } = Astro.props as BlockProps;
const about = await getAbout();
const rendered = about ? await render(about) : null;
const Content = rendered?.Content;
const d = about?.data;
---

{
  d && Content && (
    <Section
      tone={tone}
      backgroundImage={backgroundImage}
      backgroundAlt={backgroundAlt}
      parallax={parallax}
      padding="tight"
      innerClass="about-grid"
    >
      <div class="about-portrait">
        <Image
          path={d.portrait}
          alt={d.portraitAlt}
          aspect="4/5"
          sizes="(max-width: 900px) 90vw, 440px"
          placeholderLabel="Andy Lewis"
        />
      </div>
      <div class="about-bio prose">
        <Content />
      </div>
    </Section>
  )
}

<style>
  .about-grid {
    display: grid;
    gap: 2.5rem;
    align-items: start;
  }
  @media (min-width: 900px) {
    .about-grid {
      grid-template-columns: 0.8fr 1.2fr;
      gap: 4rem;
    }
    .about-portrait {
      position: sticky;
      top: 6rem;
    }
  }
  .about-portrait :global(img),
  .about-portrait :global(.media-placeholder) {
    width: 100%;
    border-radius: var(--radius-lg);
    border: 1px solid var(--color-line);
  }
  .about-bio {
    max-width: none;
  }
</style>
