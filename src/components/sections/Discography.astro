---
/**
 * Discography block — the full release grid (albums, EPs, singles).
 * `limit` caps the count; default shows all.
 */
import Section from '@components/layout/Section.astro';
import SectionHeader from '@components/ui/SectionHeader.astro';
import MusicCard from '@components/cards/MusicCard.astro';
import { getAlbums } from '@lib/content';
import { take, type BlockProps } from '@lib/blocks';

const {
  heading = 'Music',
  subheading,
  tone = 'dark',
  backgroundImage,
  backgroundAlt,
  parallax = false,
  limit,
} = Astro.props as BlockProps;
const albums = take(await getAlbums(), limit ?? 0, 0);
---

{
  albums.length > 0 && (
    <Section tone={tone} backgroundImage={backgroundImage} backgroundAlt={backgroundAlt} parallax={parallax}>
      {
        heading || subheading ? (
          <SectionHeader kicker="Discography" heading={heading} subheading={subheading} />
        ) : (
          <h2 class="sr-only">Music</h2>
        )
      }
      <div class="grid-cards">
        {albums.map((album) => (
          <MusicCard album={album} />
        ))}
      </div>
    </Section>
  )
}

<style>
  .grid-cards {
    display: grid;
    gap: 1.5rem;
    grid-template-columns: repeat(auto-fill, minmax(min(100%, 230px), 1fr));
  }
</style>
