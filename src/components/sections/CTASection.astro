---
/**
 * CTASection — the recurring "let's work together" call to action.
 * Renders inside a toned Section; defaults to the homepage CTA content.
 */
import Section from '@components/layout/Section.astro';
import Button from '@components/ui/Button.astro';
import { home } from '@lib/pages';
import type { Tone } from '@lib/pages';

interface Props {
  heading?: string;
  body?: string;
  primary?: { label: string; href: string };
  secondary?: { label: string; href: string } | null;
  tone?: Tone;
  backgroundImage?: string;
  backgroundAlt?: string;
  parallax?: boolean;
}
const {
  heading = home.cta.heading,
  body = home.cta.body,
  primary = home.cta.primaryCta,
  secondary = home.cta.secondaryCta ?? null,
  backgroundImage,
  backgroundAlt,
  parallax = false,
} = Astro.props;

// CTA bands are always the accent (green) colour.
---

<Section tone="accent" backgroundImage={backgroundImage} backgroundAlt={backgroundAlt} parallax={parallax} class="cta-section">
  <div class="cta-inner" data-reveal>
    <h2 class="cta-heading">{heading}</h2>
    <p class="cta-body">{body}</p>
    <div class="cta-actions">
      <Button href={primary.href} variant="primary" icon="arrow-right">{primary.label}</Button>
      {secondary && <Button href={secondary.href} variant="ghost">{secondary.label}</Button>}
    </div>
  </div>
</Section>

<style>
  .cta-section {
    text-align: center;
  }
  .cta-glow {
    position: absolute;
    inset: 0 20% auto;
    top: -10%;
    height: 70%;
    background: radial-gradient(50% 100% at 50% 0%, rgba(154, 205, 51, 0.16), transparent 70%);
    pointer-events: none;
    z-index: 0;
  }
  .cta-inner {
    position: relative;
    z-index: 1;
    display: grid;
    gap: 1.25rem;
    justify-items: center;
  }
  .cta-heading {
    font-size: var(--text-h1);
    max-width: 18ch;
  }
  .cta-body {
    margin: 0;
    max-width: 48ch;
    color: var(--color-ink-muted);
    font-size: var(--text-lead);
  }
  .cta-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    justify-content: center;
    margin-top: 0.5rem;
  }
</style>
