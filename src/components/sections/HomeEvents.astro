---
import Section from '@components/layout/Section.astro';
import SectionHeader from '@components/ui/SectionHeader.astro';
import EventCard from '@components/cards/EventCard.astro';
import { getEvents } from '@lib/content';
import type { Tone } from '@lib/pages';

interface Props {
  heading?: string;
  subheading?: string;
  tone?: Tone;
  backgroundImage?: string;
  backgroundAlt?: string;
  parallax?: boolean;
}
const {
  heading = 'Upcoming Shows',
  subheading,
  tone = 'dark',
  backgroundImage,
  backgroundAlt,
  parallax = false,
} = Astro.props;
const { upcoming } = await getEvents();
const shows = upcoming.slice(0, 4);
---

<Section tone={tone} backgroundImage={backgroundImage} backgroundAlt={backgroundAlt} parallax={parallax}>
  <SectionHeader kicker="Live" heading={heading} subheading={subheading} href="/events/" />
  {
    shows.length > 0 ? (
      <div class="event-list">
        {shows.map((event) => (
          <EventCard event={event} variant="upcoming" />
        ))}
      </div>
    ) : (
      <p class="no-shows">No dates on the calendar right now — new shows announced here first.</p>
    )
  }
</Section>

<style>
  .event-list {
    display: grid;
    gap: 1rem;
  }
  .no-shows {
    margin: 0;
    color: var(--color-ink-muted);
    font-size: var(--text-lead);
  }
</style>
