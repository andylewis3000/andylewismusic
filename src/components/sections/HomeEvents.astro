---
import Section from '@components/layout/Section.astro';
import SectionHeader from '@components/ui/SectionHeader.astro';
import EventCard from '@components/cards/EventCard.astro';
import { getEvents } from '@lib/content';
import { take, type BlockProps } from '@lib/blocks';

const {
  kicker,
  heading = 'Upcoming Shows',
  subheading,
  tone = 'dark',
  backgroundImage,
  backgroundAlt,
  parallax = false,
  limit,
} = Astro.props as BlockProps;
const { upcoming } = await getEvents();
const shows = take(upcoming, limit, 4);
---

<Section tone={tone} backgroundImage={backgroundImage} backgroundAlt={backgroundAlt} parallax={parallax}>
  {
    heading || subheading ? (
      <SectionHeader kicker={kicker} heading={heading} subheading={subheading} href="/events/" />
    ) : (
      <h2 class="sr-only">Upcoming shows</h2>
    )
  }
  {
    shows.length > 0 ? (
      <div class="event-list">
        {shows.map((event) => (
          <EventCard event={event} variant="upcoming" />
        ))}
      </div>
    ) : (
      <p class="no-shows">No dates on the calendar right now — new shows announced here first.</p>
    )
  }
</Section>

<style>
  .event-list {
    display: grid;
    gap: 1rem;
  }
  .no-shows {
    margin: 0;
    color: var(--color-ink-muted);
    font-size: var(--text-lead);
  }
</style>
