---
/**
 * About experience block — the professional timeline (from about.md).
 */
import Section from '@components/layout/Section.astro';
import { getAbout } from '@lib/content';
import type { BlockProps } from '@lib/blocks';

const {
  heading = 'Experience',
  tone = 'white',
  backgroundImage,
  backgroundAlt,
  parallax = false,
} = Astro.props as BlockProps;
const about = await getAbout();
const experience = about?.data.experience ?? [];
---

{
  experience.length > 0 && (
    <Section
      tone={tone}
      backgroundImage={backgroundImage}
      backgroundAlt={backgroundAlt}
      parallax={parallax}
      padding="tight"
      innerClass="two-col"
    >
      <h2 class="col-title">{heading}</h2>
      <ol class="timeline">
        {experience.map((item) => (
          <li class="timeline-item">
            <span class="timeline-year">{item.year}</span>
            <div>
              <h3 class="timeline-title">{item.title}</h3>
              {item.detail && <p class="timeline-detail">{item.detail}</p>}
            </div>
          </li>
        ))}
      </ol>
    </Section>
  )
}

<style>
  .two-col {
    display: grid;
    gap: 1.5rem;
  }
  @media (min-width: 820px) {
    .two-col {
      grid-template-columns: 14rem 1fr;
      gap: 3rem;
    }
  }
  .col-title {
    font-size: var(--text-h3);
  }
  .timeline {
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .timeline-item {
    display: grid;
    grid-template-columns: 5rem 1fr;
    gap: 1.5rem;
    padding: 1.4rem 0;
    border-top: 1px solid var(--color-line);
  }
  .timeline-item:first-child {
    border-top: 0;
  }
  .timeline-year {
    color: var(--color-accent-ink);
    font-weight: 600;
    font-size: var(--text-small);
    padding-top: 0.2rem;
  }
  .timeline-title {
    font-size: var(--text-h4);
  }
  .timeline-detail {
    margin: 0.35rem 0 0;
    color: var(--color-ink-muted);
    font-size: var(--text-small);
  }
</style>
