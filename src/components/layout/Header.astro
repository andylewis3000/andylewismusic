---
/**
 * Header — sticky, glass navigation. Desktop shows inline nav + CTA; below
 * 900px the MobileMenu island takes over. Becomes more opaque once scrolled.
 * All content is CMS-driven via the navigation + site singletons.
 */
import { navigation, site } from '@lib/settings';
import { getHiddenHrefs, filterLinks, linkHidden } from '@lib/pages';
import Button from '@components/ui/Button.astro';
import MobileMenu from './MobileMenu.astro';

const path = Astro.url.pathname;
const isActive = (href: string) => (href === '/' ? path === '/' : path.startsWith(href));

// Drop links to hidden pages from the nav.
const hidden = await getHiddenHrefs();
const primaryNav = filterLinks(navigation.primary, hidden);
const cta = navigation.cta && !linkHidden(navigation.cta.href, hidden) ? navigation.cta : null;
---

<header class="site-header glass" data-header>
  <div class="container-page header-inner">
    <a href="/" class="wordmark" aria-label={`${site.name} — home`}>
      {site.name}<span class="wordmark-dot" aria-hidden="true">.</span>
    </a>

    <nav class="primary-nav" aria-label="Primary">
      <ul>
        {
          primaryNav.map((item) => (
            <li>
              <a href={item.href} aria-current={isActive(item.href) ? 'page' : undefined}>
                {item.label}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>

    <div class="header-actions">
      {
        cta && (
          <Button href={cta.href} variant="primary" class="header-cta">
            {cta.label}
          </Button>
        )
      }
      <MobileMenu links={primaryNav} cta={cta} currentPath={path} />
    </div>
  </div>
</header>

<script is:inline>
  // Toggle a "scrolled" state for the glass header. Re-bound after each
  // view transition so it keeps working during SPA-style navigation.
  (function () {
    function bind() {
      const header = document.querySelector('[data-header]');
      if (!header) return;
      const onScroll = () => header.classList.toggle('is-scrolled', window.scrollY > 8);
      onScroll();
      window.addEventListener('scroll', onScroll, { passive: true });
    }
    bind();
    document.addEventListener('astro:after-swap', bind);
  })();
</script>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    border: 0;
    border-bottom: 1px solid transparent;
    /* Light glass over any content; dark text stays readable. */
    background: var(--glass-bg);
    -webkit-backdrop-filter: blur(var(--glass-blur));
    backdrop-filter: blur(var(--glass-blur));
    transition:
      border-color var(--dur-base) var(--ease-standard),
      box-shadow var(--dur-base) var(--ease-standard);
  }
  /* Add definition once scrolled. */
  .site-header.is-scrolled {
    border-bottom-color: var(--color-line);
    box-shadow: var(--shadow-sm);
  }

  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    height: 4.5rem;
  }

  .wordmark {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: 1.4rem;
    letter-spacing: 0.02em;
    text-transform: uppercase;
    color: var(--color-ink);
    white-space: nowrap;
  }
  .wordmark-dot {
    color: var(--color-accent);
  }

  .primary-nav {
    display: none;
  }
  .primary-nav ul {
    display: flex;
    gap: 0.35rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .primary-nav a {
    display: inline-block;
    padding: 0.5rem 0.9rem;
    font-size: var(--text-small);
    font-weight: 500;
    color: var(--color-ink-muted);
    border-radius: var(--radius-sm);
    transition:
      color var(--dur-base) var(--ease-standard),
      background-color var(--dur-base) var(--ease-standard);
  }
  .primary-nav a:hover {
    color: var(--color-ink);
    background: rgba(244, 242, 238, 0.04);
  }
  .primary-nav a[aria-current='page'] {
    color: var(--color-accent);
  }

  .header-actions {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }
  .header-cta {
    display: none;
  }

  @media (min-width: 900px) {
    .primary-nav {
      display: block;
    }
    .header-cta {
      display: inline-flex;
    }
  }
</style>
