---
/**
 * Header — sticky, glass navigation. Desktop shows inline nav + CTA; below
 * 900px the MobileMenu island takes over. Becomes more opaque once scrolled.
 * All content is CMS-driven via the navigation + site singletons.
 */
import { navigation, site } from '@lib/settings';
import { getHiddenHrefs, linkHidden } from '@lib/pages';
import { getMainMenu } from '@lib/menus';
import { hasImage } from '@lib/images';
import Image from '@components/media/Image.astro';
import Button from '@components/ui/Button.astro';
import MobileMenu from './MobileMenu.astro';

// A logo replaces the text wordmark when one is uploaded in Site Settings.
const showLogo = hasImage(site.headerLogo);
const logoWidth = site.headerLogoWidth;

const path = Astro.url.pathname;
const isActive = (href: string) => (href === '/' ? path === '/' : path.startsWith(href));

// The header shows the published "main" menu (falls back to Navigation settings).
const primaryNav = await getMainMenu();
// The CTA button still comes from Navigation settings; drop it if hidden.
const hidden = await getHiddenHrefs();
const cta = navigation.cta && !linkHidden(navigation.cta.href, hidden) ? navigation.cta : null;
---

<header class="site-header glass" data-header>
  <div class="container-page header-inner">
    <a
      href="/"
      class:list={['brand', { wordmark: !showLogo }]}
      aria-label={`${site.name} — home`}
      style={showLogo ? `--logo-w:${logoWidth}px` : undefined}
    >
      {
        showLogo ? (
          <Image
            path={site.headerLogo}
            alt={site.name}
            class="brand-logo"
            widths={[logoWidth, logoWidth * 2]}
            sizes={`${logoWidth}px`}
            loading="eager"
            fetchpriority="high"
          />
        ) : (
          <>
            {site.name}
            <span class="wordmark-dot" aria-hidden="true">
              .
            </span>
          </>
        )
      }
    </a>

    <nav class="primary-nav" aria-label="Primary">
      <ul>
        {
          primaryNav.map((item) => (
            <li>
              <a href={item.href} aria-current={isActive(item.href) ? 'page' : undefined}>
                {item.label}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>

    <div class="header-actions">
      {
        cta && (
          <Button href={cta.href} variant="primary" class="header-cta">
            {cta.label}
          </Button>
        )
      }
      <MobileMenu links={primaryNav} cta={cta} currentPath={path} />
    </div>
  </div>
</header>

<script is:inline>
  // Toggle a "scrolled" state for the glass header. Re-bound after each
  // view transition so it keeps working during SPA-style navigation.
  (function () {
    function bind() {
      const header = document.querySelector('[data-header]');
      if (!header) return;
      const onScroll = () => header.classList.toggle('is-scrolled', window.scrollY > 8);
      onScroll();
      window.addEventListener('scroll', onScroll, { passive: true });
    }
    bind();
    document.addEventListener('astro:after-swap', bind);
  })();
</script>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    border: 0;
    border-bottom: 1px solid transparent;
    /* Light glass over any content; dark text stays readable. */
    background: var(--glass-bg);
    -webkit-backdrop-filter: blur(var(--glass-blur));
    backdrop-filter: blur(var(--glass-blur));
    transition:
      border-color var(--dur-base) var(--ease-standard),
      box-shadow var(--dur-base) var(--ease-standard);
  }
  /* Add definition once scrolled. */
  .site-header.is-scrolled {
    border-bottom-color: var(--color-line);
    box-shadow: var(--shadow-sm);
  }

  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    height: 4.5rem;
  }

  .brand {
    display: inline-flex;
    align-items: center;
  }
  .wordmark {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: 1.4rem;
    letter-spacing: 0.02em;
    text-transform: uppercase;
    color: var(--color-ink);
    white-space: nowrap;
  }
  .wordmark-dot {
    color: var(--color-accent);
  }
  /* Uploaded logo: width is CMS-controlled, height stays proportional. */
  .brand :global(.brand-logo) {
    display: block;
    width: var(--logo-w);
    height: auto;
  }

  .primary-nav {
    display: none;
  }
  .primary-nav ul {
    display: flex;
    gap: 0.35rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .primary-nav a {
    display: inline-block;
    padding: 0.5rem 0.9rem;
    font-family: var(--font-display);
    font-weight: 400;
    font-size: 1.15rem;
    letter-spacing: 0.03em;
    text-transform: uppercase;
    color: var(--color-ink);
    text-decoration: underline 3px transparent;
    text-underline-offset: 6px;
    transition: text-decoration-color var(--dur-base) var(--ease-standard);
  }
  .primary-nav a:hover,
  .primary-nav a[aria-current='page'] {
    color: var(--color-ink);
    text-decoration-color: var(--color-accent);
  }

  .header-actions {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }
  .header-cta {
    display: none;
  }

  @media (min-width: 900px) {
    .primary-nav {
      display: block;
    }
    .header-cta {
      display: inline-flex;
    }
  }
</style>
