---
/**
 * Pages — renders every page in the `pages` collection at /<slug>/ from the
 * shared section library. The file name is the slug (music.json → /music/).
 * `blog` is excluded here because it has its own paginated route. Drafts are
 * dropped from the production build.
 */
import type { GetStaticPaths } from 'astro';
import { getCollection } from 'astro:content';
import BaseLayout from '@layouts/BaseLayout.astro';
import PageHero from '@components/sections/PageHero.astro';
import SectionRenderer from '@components/sections/SectionRenderer.astro';

export const getStaticPaths = (async () => {
  const all = await getCollection('pages', (entry) =>
    import.meta.env.PROD ? entry.data.draft !== true : true
  );
  return all
    .filter((page) => page.id !== 'blog')
    .map((page) => ({ params: { slug: page.id }, props: { page } }));
}) satisfies GetStaticPaths;

const { page } = Astro.props;
const d = page.data;
---

<BaseLayout
  title={d.title}
  description={d.seo.description ?? d.hero.intro}
  noindex={d.seo.noindex}
>
  <PageHero
    kicker={d.hero.kicker}
    title={d.hero.heading}
    intro={d.hero.intro}
    tone={d.hero.background}
    backgroundImage={d.hero.backgroundImage}
    backgroundAlt={d.hero.backgroundAlt}
    parallax={d.hero.parallax}
  />
  {d.sections.map((section) => <SectionRenderer section={section} />)}
</BaseLayout>
