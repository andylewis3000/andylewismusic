---
/**
 * Music detail — a single release. The hero uses the album artwork as an
 * immersive (blurred, scrimmed) background by default, with the sharp cover,
 * title, streaming links, tracklist, embeds, credits and liner notes below.
 */
import type { GetStaticPaths } from 'astro';
import { render } from 'astro:content';
import { getImage } from 'astro:assets';
import BaseLayout from '@layouts/BaseLayout.astro';
import Image from '@components/media/Image.astro';
import Button from '@components/ui/Button.astro';
import Icon from '@components/ui/Icon.astro';
import CTASection from '@components/sections/CTASection.astro';
import RelatedAlbums from '@components/sections/RelatedAlbums.astro';
import { getAlbums } from '@lib/content';
import { resolveImage } from '@lib/images';
import { formatDate, year } from '@lib/format';
import { musicAlbumSchema, breadcrumbSchema, resolveImageUrl } from '@lib/seo';
import type { IconName } from '@components/ui/icons';

export const getStaticPaths = (async () => {
  const albums = await getAlbums();
  return albums.map((album) => ({ params: { slug: album.id }, props: { album } }));
}) satisfies GetStaticPaths;

const { album } = Astro.props;
const d = album.data;
const { Content } = await render(album);
const typeLabel = d.type === 'ep' ? 'EP' : d.type.charAt(0).toUpperCase() + d.type.slice(1);
const hasBody = (album.body ?? '').trim().length > 0;

// An unreleased record shows pre-save / notify CTAs instead of streaming links.
const isUpcoming = +d.releaseDate > Date.now();

const linkDefs: { key: keyof typeof d.links; label: string; icon: IconName }[] = [
  { key: 'spotify', label: 'Spotify', icon: 'spotify' },
  { key: 'appleMusic', label: 'Apple Music', icon: 'appleMusic' },
  { key: 'bandcamp', label: 'Bandcamp', icon: 'bandcamp' },
  { key: 'youtube', label: 'YouTube', icon: 'youtube' },
  { key: 'soundcloud', label: 'SoundCloud', icon: 'soundcloud' },
];
const links = linkDefs.filter((l) => d.links[l.key]);

// Blurred artwork background for the hero (small — blur hides detail).
const coverMeta = resolveImage(d.cover);
const heroBg = coverMeta ? (await getImage({ src: coverMeta, width: 640, format: 'webp' })).src : undefined;

const coverUrl = await resolveImageUrl(d.cover);
const schemas = [
  musicAlbumSchema(album, coverUrl),
  breadcrumbSchema([
    { name: 'Home', url: '/' },
    { name: 'Music', url: '/music/' },
    { name: d.title, url: `/music/${album.id}/` },
  ]),
];
---

<BaseLayout title={d.title} description={d.description} image={d.cover} type="music.album" schemas={schemas}>
  <header class="album-hero" data-tone="dark">
    {heroBg && <div class="album-hero-bg" style={`background-image:url('${heroBg}')`} aria-hidden="true"></div>}
    <div class="album-hero-scrim" aria-hidden="true"></div>
    <div class="container-page album-hero-inner">
      <a class="back" href="/music/">
        <Icon name="arrow-right" size={16} class="flip" /> All music
      </a>
      <div class="album-info">
        <span class="kicker">
          {isUpcoming ? `${typeLabel} · Out ${formatDate(d.releaseDate)}` : `${typeLabel} · ${year(d.releaseDate)}`}
        </span>
        <h1 class="album-title">{d.title}</h1>
        <h2 class="album-artist">{d.artist}</h2>
      </div>
    </div>
  </header>

  <section class="section-tight">
    <div class="container-page detail-cols">
      <div class="tracklist-wrap">
        <div class="album-cover">
          <Image
            path={d.cover}
            alt={d.coverAlt}
            aspect="1/1"
            sizes="(max-width: 900px) 90vw, 420px"
            loading="eager"
            placeholderLabel={d.title}
          />
        </div>
        {
          d.tracklist.length > 0 && (
            <>
              <h2 class="detail-h">Tracklist</h2>
              <ol class="tracklist">
                {d.tracklist.map((track, i) => (
                  <li>
                    <span class="track-no">{String(i + 1).padStart(2, '0')}</span>
                    <span class="track-title">{track.title}</span>
                    {track.duration && <span class="track-dur">{track.duration}</span>}
                  </li>
                ))}
              </ol>
            </>
          )
        }
      </div>

      <div class="detail-side">
        <div class="release-intro">
          {
            isUpcoming ? (
              <div class="release-links">
                {d.preSaveUrl && (
                  <Button href={d.preSaveUrl} variant="primary" icon="spotify" iconPosition="start">
                    Pre-save
                  </Button>
                )}
                <Button href="/#newsletter" variant="secondary" icon="arrow-right" iconPosition="end">
                  Notify me on release
                </Button>
              </div>
            ) : (
              links.length > 0 && (
                <div class="release-links">
                  {links.map((l) => (
                    <Button href={d.links[l.key]} variant="secondary" icon={l.icon} iconPosition="start">
                      {l.label}
                    </Button>
                  ))}
                </div>
              )
            )
          }
          <p class="album-desc">{d.description}</p>
        </div>
        <dl class="release-facts">
          <div><dt>{isUpcoming ? 'Releases' : 'Released'}</dt><dd>{formatDate(d.releaseDate)}</dd></div>
          {d.label && <div><dt>Label</dt><dd>{d.label}</dd></div>}
          {d.roles.length > 0 && (
            <div><dt>Andy plays</dt><dd>{d.roles.join(', ')}</dd></div>
          )}
        </dl>
        {
          hasBody && (
            <div class="liner prose">
              <h2 class="detail-h">Liner notes</h2>
              <Content />
            </div>
          )
        }
        {
          d.credits.length > 0 && (
            <div class="credits">
              <h2 class="detail-h">Credits</h2>
              <dl>
                {d.credits.map((c) => (
                  <div class="credit">
                    <dt>{c.role}</dt>
                    <dd>{c.name}</dd>
                  </div>
                ))}
              </dl>
            </div>
          )
        }
      </div>
    </div>
  </section>

  <RelatedAlbums album={album} tone="grey" kicker="More to hear" heading="Related albums" />

  <CTASection />
</BaseLayout>

<style>
  .album-hero {
    position: relative;
    overflow: hidden;
    padding-block: clamp(3rem, 2rem + 6vw, 6rem);
    border-bottom: 1px solid var(--color-line);
    background: var(--color-bg);
  }
  .album-hero-bg {
    position: absolute;
    inset: -12%;
    background-size: cover;
    background-position: center;
    filter: blur(8px) brightness(0.78) saturate(1.05);
    transform: scale(1.06);
    z-index: 0;
  }
  .album-hero-scrim {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(10, 10, 11, 0.2), rgba(10, 10, 11, 0.42));
    z-index: 0;
  }
  .album-hero-inner {
    position: relative;
    z-index: 1;
  }
  .back {
    display: inline-flex;
    align-items: center;
    gap: 0.35em;
    margin-bottom: 2rem;
    color: rgba(255, 255, 255, 0.8);
    font-size: var(--text-small);
  }
  .back:hover {
    color: var(--color-ink);
  }
  .flip {
    transform: rotate(180deg);
  }
  .album-info {
    display: grid;
    gap: 0.7rem;
    max-width: 60ch;
  }
  /* Sharp cover, now placed above the tracklist. */
  .album-cover {
    width: 100%;
    max-width: 22rem;
    margin-bottom: 2.5rem;
  }
  .album-cover :global(img),
  .album-cover :global(.media-placeholder) {
    width: 100%;
    border-radius: var(--radius-lg);
    border: 1px solid var(--color-line);
    box-shadow: var(--shadow-md);
  }
  .album-title {
    font-size: var(--text-display);
    color: #fff;
  }
  .album-artist {
    margin: 0;
    font-size: var(--text-h3);
    color: rgba(255, 255, 255, 0.85);
  }
  .album-hero :global(.kicker) {
    color: rgba(255, 255, 255, 0.85);
  }
  .album-desc {
    margin: 0.15rem 0 0;
    font-size: var(--text-lead);
    color: var(--color-ink);
    max-width: 52ch;
  }
  .release-links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin: 0 0 1.1rem;
  }

  .detail-cols {
    display: grid;
    gap: 2.5rem;
  }
  @media (min-width: 900px) {
    .detail-cols {
      grid-template-columns: 1.1fr 0.9fr;
      gap: 4rem;
    }
  }
  .detail-h {
    font-size: var(--text-h3);
    margin-bottom: 1.25rem;
  }
  .tracklist {
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .tracklist li {
    display: grid;
    grid-template-columns: 2.5rem 1fr auto;
    align-items: center;
    gap: 1rem;
    padding: 0.85rem 0;
    border-top: 1px solid var(--color-line);
  }
  .tracklist li:first-child {
    border-top: 0;
  }
  .track-no {
    color: var(--color-accent-ink);
    font-family: var(--font-display);
    font-weight: 700;
    font-size: var(--text-small);
  }
  .track-title {
    color: var(--color-ink);
  }
  .track-dur {
    color: var(--color-ink-faint);
    font-size: var(--text-small);
    font-variant-numeric: tabular-nums;
  }
  .detail-side {
    display: grid;
    gap: 2.5rem;
    align-content: start;
  }
  .release-facts {
    display: grid;
    gap: 0.75rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid var(--color-line);
  }
  .release-facts div {
    display: grid;
    grid-template-columns: 8rem 1fr;
    gap: 1rem;
  }
  .release-facts dt {
    color: var(--color-ink-faint);
    font-size: var(--text-small);
  }
  .release-facts dd {
    margin: 0;
    color: var(--color-ink);
    font-size: var(--text-small);
    text-transform: capitalize;
  }
  .credits dl {
    margin: 0;
    display: grid;
    gap: 0.65rem;
  }
  .credit {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 1rem;
    padding-bottom: 0.65rem;
    border-bottom: 1px solid var(--color-line);
  }
  .credit dt {
    color: var(--color-ink-muted);
    font-size: var(--text-small);
  }
  .credit dd {
    margin: 0;
    color: var(--color-ink);
    font-size: var(--text-small);
  }
</style>
