---
/**
 * Music — the full discography grid (albums, EPs, singles). Each card links
 * to a detail page with embeds and tracklist.
 */
import BaseLayout from '@layouts/BaseLayout.astro';
import PageHero from '@components/sections/PageHero.astro';
import MusicCard from '@components/cards/MusicCard.astro';
import CTASection from '@components/sections/CTASection.astro';
import { getAlbums } from '@lib/content';

const albums = await getAlbums();
---

<BaseLayout
  title="Music"
  description="Albums, EPs and singles by Andy Lewis — stream on Spotify, Apple Music and Bandcamp."
>
  <PageHero
    kicker="Discography"
    title="Music"
    intro="Records built around live drums, guitar and analogue texture. Stream anywhere, or dig into the liner notes."
  />

  <section class="section-tight" aria-label="Releases">
    <div class="container-page">
      <h2 class="sr-only">Releases</h2>
      {
        albums.length > 0 ? (
          <div class="grid-cards">
            {albums.map((album) => (
              <MusicCard album={album} />
            ))}
          </div>
        ) : (
          <p class="empty">Releases are on the way — check back soon.</p>
        )
      }
    </div>
  </section>

  <CTASection />
</BaseLayout>

<style>
  .grid-cards {
    display: grid;
    gap: 1.5rem;
    grid-template-columns: repeat(auto-fill, minmax(min(100%, 230px), 1fr));
  }
  .empty {
    color: var(--color-ink-muted);
    font-size: var(--text-lead);
  }
</style>
