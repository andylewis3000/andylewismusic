---
/**
 * About — hero + composable sections (Pages → About in the CMS). The bio,
 * highlights, timeline, influences and equipment are section blocks.
 */
import BaseLayout from '@layouts/BaseLayout.astro';
import PageHero from '@components/sections/PageHero.astro';
import SectionRenderer from '@components/sections/SectionRenderer.astro';
import { getAbout } from '@lib/content';

const about = await getAbout();
if (!about) throw new Error('About content is missing (src/content/about/about.md).');
const d = about.data;
---

<BaseLayout title={d.title} description={d.seo.description ?? d.headline} image={d.portrait}>
  <PageHero
    kicker={d.hero.kicker ?? 'About'}
    title={d.headline}
    tone={d.hero.background}
    backgroundImage={d.hero.backgroundImage}
    backgroundAlt={d.hero.backgroundAlt}
    parallax={d.hero.parallax}
  />
  {d.sections.map((section) => <SectionRenderer section={section} />)}
</BaseLayout>
