---
/**
 * Blog article — full post with hero, prose body, tags and related posts.
 * The <article> is marked for Pagefind indexing (data-pagefind-body).
 */
import type { GetStaticPaths } from 'astro';
import { render } from 'astro:content';
import { getImage } from 'astro:assets';
import BaseLayout from '@layouts/BaseLayout.astro';
import Icon from '@components/ui/Icon.astro';
import BlogCard from '@components/cards/BlogCard.astro';
import { getPosts, getRelatedPosts } from '@lib/content';
import { resolveImage } from '@lib/images';
import { formatDate, isoDate, readingTime } from '@lib/format';
import { articleSchema, breadcrumbSchema, resolveImageUrl } from '@lib/seo';

export const getStaticPaths = (async () => {
  const posts = await getPosts();
  return posts.map((post) => ({ params: { slug: post.id }, props: { post } }));
}) satisfies GetStaticPaths;

const { post } = Astro.props;
const d = post.data;
const { Content } = await render(post);
const related = await getRelatedPosts(post, 3);
const minutes = readingTime(post.body ?? '');

// Sharp hero image used as an immersive, scrimmed banner behind the title.
const heroMeta = resolveImage(d.heroImage);
const heroBg = heroMeta ? (await getImage({ src: heroMeta, width: 1600, format: 'webp' })).src : undefined;

const heroUrl = await resolveImageUrl(d.heroImage);
const schemas = [
  articleSchema(post, heroUrl),
  breadcrumbSchema([
    { name: 'Home', url: '/' },
    { name: 'News', url: '/blog/' },
    { name: d.title, url: `/blog/${post.id}/` },
  ]),
];
---

<BaseLayout
  title={d.title}
  description={d.description}
  image={d.heroImage}
  type="article"
  publishedTime={isoDate(d.publishDate)}
  modifiedTime={d.updatedDate ? isoDate(d.updatedDate) : undefined}
  schemas={schemas}
>
  <article class="post" data-pagefind-body>
    <header class="post-hero" data-tone="dark" data-has-image={heroBg ? 'true' : undefined}>
      {heroBg && <div class="post-hero-bg" style={`background-image:url('${heroBg}')`} aria-hidden="true" />}
      <div class="post-hero-scrim" aria-hidden="true"></div>
      <div class="container-page post-hero-inner">
        <nav class="crumbs" aria-label="Breadcrumb">
          <a href="/blog/"><Icon name="arrow-right" size={14} class="flip" /> News</a>
          <span aria-hidden="true">/</span>
          <a href={`/blog/category/${d.category}/`} class="crumb-cat">{d.category}</a>
        </nav>
        <h1 class="post-title">{d.title}</h1>
        <p class="post-meta">
          <time datetime={isoDate(d.publishDate)}>{formatDate(d.publishDate)}</time>
          <span aria-hidden="true">·</span>
          <span>{minutes}</span>
          <span aria-hidden="true">·</span>
          <span>{d.author}</span>
        </p>
      </div>
    </header>

    <div class="container-page section-tight">
      <div class="post-body prose">
        <Content />
      </div>

      {
        d.tags.length > 0 && (
          <div class="post-tags">
            {d.tags.map((tag) => (
              <a href={`/blog/tag/${tag}/`} class="tag">
                #{tag}
              </a>
            ))}
          </div>
        )
      }
    </div>
  </article>

  {
    related.length > 0 && (
      <section class="section related">
        <div class="container-page">
          <h2 class="related-h">Related reading</h2>
          <div class="grid-news">
            {related.map((p) => (
              <BlogCard post={p} />
            ))}
          </div>
        </div>
      </section>
    )
  }
</BaseLayout>

<style>
  /* Immersive hero — sharp image banner with a scrim and white text,
     mirroring the album detail hero. */
  .post-hero {
    position: relative;
    overflow: hidden;
    padding-block: clamp(3rem, 2rem + 6vw, 6rem);
    border-bottom: 1px solid var(--color-line);
    background: var(--tone-bg);
  }
  .post-hero[data-has-image] {
    padding-block: clamp(4rem, 3rem + 10vw, 9rem);
  }
  .post-hero-bg {
    position: absolute;
    inset: 0;
    background-size: cover;
    background-position: center;
    z-index: 0;
  }
  .post-hero-scrim {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(10, 10, 11, 0.35), rgba(10, 10, 11, 0.68));
    z-index: 0;
  }
  .post-hero-inner {
    position: relative;
    z-index: 1;
    display: grid;
    justify-items: start;
    gap: 1rem;
    text-align: left;
  }
  .crumbs {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    color: rgba(255, 255, 255, 0.75);
    font-size: var(--text-small);
  }
  .crumbs a {
    display: inline-flex;
    align-items: center;
    gap: 0.3em;
    text-transform: capitalize;
  }
  .crumbs a:hover {
    color: #fff;
  }
  .flip {
    transform: rotate(180deg);
  }
  .post-title {
    font-size: var(--text-h1);
    max-width: 20ch;
    color: #fff;
  }
  .post-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
    margin: 0;
    color: rgba(255, 255, 255, 0.75);
    font-size: var(--text-small);
  }
  /* Body spans the full page container rather than a narrow reading column. */
  .post-body {
    max-width: none;
  }
  .post-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin: 3rem 0 0;
    padding-top: 1.75rem;
    border-top: 1px solid var(--color-line);
  }
  .tag {
    display: inline-flex;
    align-items: center;
    padding: 0.5em 1em;
    background: var(--color-surface-2);
    color: var(--color-ink-muted);
    font-size: var(--text-small);
    font-weight: 600;
    border-radius: var(--radius-md);
    transition:
      background-color var(--dur-base) var(--ease-standard),
      color var(--dur-base) var(--ease-standard);
  }
  .tag:hover {
    color: var(--color-ink);
    background: var(--color-line);
  }
  .related-h {
    font-size: var(--text-h3);
    margin-bottom: 1.75rem;
  }
  .grid-news {
    display: grid;
    gap: 1.75rem;
    grid-template-columns: repeat(auto-fill, minmax(min(100%, 300px), 1fr));
  }
</style>
