---
/**
 * Blog index — paginated news listing with client-side search (Pagefind).
 * Hero + section styling from the CMS (Pages → News). Page 1 at /blog/.
 */
import type { GetStaticPaths } from 'astro';
import { getEntry } from 'astro:content';
import BaseLayout from '@layouts/BaseLayout.astro';
import Section from '@components/layout/Section.astro';
import PageHero from '@components/sections/PageHero.astro';
import BlogCard from '@components/cards/BlogCard.astro';
import Pagination from '@components/ui/Pagination.astro';
import Search from '@components/ui/Search.astro';
import { getPosts, getPostTaxonomies } from '@lib/content';
import { findSection } from '@lib/pages';

export const getStaticPaths = (async ({ paginate }) => {
  // Don't build the blog if its page entry is drafted.
  const entry = await getEntry('pages', 'blog');
  if (import.meta.env.PROD && entry?.data.draft) return [];
  const posts = await getPosts();
  return paginate(posts, { pageSize: 6 });
}) satisfies GetStaticPaths;

const { page } = Astro.props;
const { categories } = await getPostTaxonomies();

const blog = await getEntry('pages', 'blog');
const p = blog!.data;
const articles = findSection(p.sections, 'articles');
---

<BaseLayout title={p.hero.heading} description={p.hero.intro} path="/blog/">
  <PageHero
    kicker={p.hero.kicker}
    title={p.hero.heading}
    intro={p.hero.intro}
    tone={p.hero.background}
    backgroundImage={p.hero.backgroundImage}
    backgroundAlt={p.hero.backgroundAlt}
    parallax={p.hero.parallax}
  />

  <Section
    tone={articles.background}
    backgroundImage={articles.backgroundImage}
    backgroundAlt={articles.backgroundAlt}
    parallax={articles.parallax}
    padding="tight"
  >
    <div class="blog-toolbar">
      {
        categories.length > 0 && (
          <nav class="cat-nav" aria-label="Post categories">
            <a href="/blog/" class="cat is-active" aria-current="page">All</a>
            {categories.map((c) => (
              <a href={`/blog/category/${c}/`} class="cat">
                {c}
              </a>
            ))}
          </nav>
        )
      }
      <Search />
    </div>

    <h2 class="sr-only">Articles</h2>
    <div class="grid-news">
      {page.data.map((post) => <BlogCard post={post} />)}
    </div>

    <Pagination page={page} base="/blog" />
  </Section>
</BaseLayout>

<style>
  .blog-toolbar {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 2.5rem;
  }
  .cat-nav {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }
  .cat {
    padding: 0.4em 0.95em;
    border-radius: 999px;
    border: 1px solid var(--color-line-strong);
    color: var(--color-ink-muted);
    font-size: var(--text-small);
    text-transform: capitalize;
    transition:
      color var(--dur-base) var(--ease-standard),
      border-color var(--dur-base) var(--ease-standard);
  }
  .cat:hover {
    color: var(--color-ink);
  }
  .cat.is-active {
    color: var(--color-accent-contrast);
    background: var(--color-accent);
    border-color: var(--color-accent);
  }
  .grid-news {
    display: grid;
    gap: 1.75rem;
    grid-template-columns: repeat(auto-fill, minmax(min(100%, 320px), 1fr));
  }
</style>
