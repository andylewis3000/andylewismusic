---
/**
 * Home — hero, a short intro statement, then the CMS-ordered, toggleable
 * homepage sections (each with its own tone/background), and the closing CTA.
 */
import BaseLayout from '@layouts/BaseLayout.astro';
import Section from '@components/layout/Section.astro';
import Hero from '@components/sections/Hero.astro';
import HomeFeaturedMusic from '@components/sections/HomeFeaturedMusic.astro';
import HomeLatestVideo from '@components/sections/HomeLatestVideo.astro';
import HomeEvents from '@components/sections/HomeEvents.astro';
import HomeNews from '@components/sections/HomeNews.astro';
import InstagramSection from '@components/sections/InstagramSection.astro';
import CTASection from '@components/sections/CTASection.astro';
import { home } from '@lib/pages';

const sections = home.sections.filter((s) => s.enabled);
---

<BaseLayout description={home.intro.body}>
  <Hero />

  <Section tone="dark" padding="tight" class="intro">
    <div data-reveal>
      <p class="kicker">Introduction</p>
      <h2 class="intro-heading">{home.intro.heading}</h2>
      <p class="intro-body">{home.intro.body}</p>
    </div>
  </Section>

  {
    sections.map((s) => {
      const style = {
        tone: s.background,
        backgroundImage: s.backgroundImage,
        backgroundAlt: s.backgroundAlt,
        parallax: s.parallax,
      };
      switch (s.id) {
        case 'featured-music':
          return <HomeFeaturedMusic heading={s.heading} subheading={s.subheading} {...style} />;
        case 'latest-video':
          return <HomeLatestVideo heading={s.heading} subheading={s.subheading} {...style} />;
        case 'events':
          return <HomeEvents heading={s.heading} subheading={s.subheading} {...style} />;
        case 'news':
          return <HomeNews heading={s.heading} subheading={s.subheading} {...style} />;
        case 'instagram':
          return <InstagramSection heading={s.heading} {...style} />;
        case 'cta':
          return <CTASection {...style} />;
        default:
          return null;
      }
    })
  }
</BaseLayout>

<style>
  .intro > div {
    display: grid;
    gap: 1.1rem;
  }
  .intro-heading {
    font-size: var(--text-h2);
    max-width: 20ch;
  }
  .intro-body {
    margin: 0;
    max-width: 62ch;
    font-size: var(--text-lead);
    color: var(--color-ink-muted);
  }
</style>
