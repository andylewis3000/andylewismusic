---
/**
 * Home — hero, a short intro statement, then the CMS-ordered, toggleable
 * homepage sections (featured music, latest video, events, news, Instagram,
 * closing CTA).
 */
import BaseLayout from '@layouts/BaseLayout.astro';
import Hero from '@components/sections/Hero.astro';
import HomeFeaturedMusic from '@components/sections/HomeFeaturedMusic.astro';
import HomeLatestVideo from '@components/sections/HomeLatestVideo.astro';
import HomeEvents from '@components/sections/HomeEvents.astro';
import HomeNews from '@components/sections/HomeNews.astro';
import InstagramSection from '@components/sections/InstagramSection.astro';
import CTASection from '@components/sections/CTASection.astro';
import { home } from '@lib/settings';

const sections = home.sections.filter((s) => s.enabled);
---

<BaseLayout description={home.intro.body}>
  <Hero />

  <section class="section-tight intro">
    <div class="container-page" data-reveal>
      <p class="kicker">Introduction</p>
      <h2 class="intro-heading">{home.intro.heading}</h2>
      <p class="intro-body">{home.intro.body}</p>
    </div>
  </section>

  {
    sections.map((s) => {
      switch (s.id) {
        case 'featured-music':
          return <HomeFeaturedMusic heading={s.heading} subheading={s.subheading} />;
        case 'latest-video':
          return <HomeLatestVideo heading={s.heading} subheading={s.subheading} />;
        case 'events':
          return <HomeEvents heading={s.heading} subheading={s.subheading} />;
        case 'news':
          return <HomeNews heading={s.heading} subheading={s.subheading} />;
        case 'instagram':
          return <InstagramSection />;
        case 'cta':
          return <CTASection />;
        default:
          return null;
      }
    })
  }
</BaseLayout>

<style>
  .intro > div {
    display: grid;
    gap: 1.1rem;
    max-width: 62rem;
  }
  .intro-heading {
    font-size: var(--text-h2);
    max-width: 20ch;
  }
  .intro-body {
    margin: 0;
    max-width: 62ch;
    font-size: var(--text-lead);
    color: var(--color-ink-muted);
  }
</style>
