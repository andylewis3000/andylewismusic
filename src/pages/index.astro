---
/**
 * Home — hero, a short intro statement, then a fully composable list of
 * sections (any block from the shared library, ordered in the CMS).
 */
import BaseLayout from '@layouts/BaseLayout.astro';
import Section from '@components/layout/Section.astro';
import Hero from '@components/sections/Hero.astro';
import SectionRenderer from '@components/sections/SectionRenderer.astro';
import { home } from '@lib/pages';
---

<BaseLayout description={home.intro.body}>
  <Hero />

  <Section tone="white" padding="tight" class="intro">
    <div data-reveal>
      <p class="kicker">Introduction</p>
      <h2 class="intro-heading">{home.intro.heading}</h2>
      <p class="intro-body">{home.intro.body}</p>
    </div>
  </Section>

  {home.sections.map((section) => <SectionRenderer section={section} />)}
</BaseLayout>

<style>
  .intro > div {
    display: grid;
    gap: 1.1rem;
  }
  .intro-heading {
    font-size: var(--text-h2);
    max-width: 20ch;
  }
  .intro-body {
    margin: 0;
    max-width: 62ch;
    font-size: var(--text-lead);
    color: var(--color-ink-muted);
  }
</style>
