---
/**
 * Contact / Booking — hero + composable sections (Pages → Contact).
 * The enquiry form is the `contact-form` block.
 */
import BaseLayout from '@layouts/BaseLayout.astro';
import PageHero from '@components/sections/PageHero.astro';
import SectionRenderer from '@components/sections/SectionRenderer.astro';
import { pages } from '@lib/pages';

const p = pages.contact;
---

<BaseLayout title={p.hero.heading} description={p.hero.intro}>
  <PageHero
    kicker={p.hero.kicker}
    title={p.hero.heading}
    intro={p.hero.intro}
    tone={p.hero.background}
    backgroundImage={p.hero.backgroundImage}
    backgroundAlt={p.hero.backgroundAlt}
    parallax={p.hero.parallax}
  />
  {p.sections.map((section) => <SectionRenderer section={section} />)}
</BaseLayout>
