---
/**
 * Contact / Booking — accessible enquiry form that posts to the Hostinger PHP
 * handler (public/form.php). Works without JavaScript (standard POST); JS adds
 * inline success/error states and Turnstile support when configured.
 */
import BaseLayout from '@layouts/BaseLayout.astro';
import PageHero from '@components/sections/PageHero.astro';
import SocialLinks from '@components/ui/SocialLinks.astro';
import Icon from '@components/ui/Icon.astro';
import { site } from '@lib/settings';

const endpoint = site.forms.endpoint;
const turnstileKey = site.forms.turnstileSiteKey;
---

<BaseLayout
  title="Contact & Booking"
  description="Book Andy Lewis for performances, sessions, collaborations and scoring, or just get in touch."
>
  {turnstileKey && <script src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer is:inline />}

  <PageHero
    kicker="Booking"
    title="Let's work together"
    intro="Performances, sessions, collaborations, scoring — tell me what you're planning and I'll get back to you personally."
  />

  <section class="section-tight">
    <div class="container-page contact-grid">
      <div class="contact-aside">
        <div class="contact-block">
          <h2 class="aside-h">Direct</h2>
          <ul class="contact-list">
            <li>
              <span class="contact-label">General</span>
              <a href={`mailto:${site.email}`}>{site.email}</a>
            </li>
            <li>
              <span class="contact-label">Booking</span>
              <a href={`mailto:${site.bookingEmail}`}>{site.bookingEmail}</a>
            </li>
            <li>
              <span class="contact-label">Based in</span>
              <span>{site.location}</span>
            </li>
          </ul>
        </div>
        <div class="contact-block">
          <h2 class="aside-h">Elsewhere</h2>
          <SocialLinks />
        </div>
      </div>

      <form
        class="contact-form"
        method="POST"
        action={endpoint}
        data-contact-form
        novalidate
      >
        <div class="field-row">
          <div class="field">
            <label for="name">Name</label>
            <input id="name" name="name" type="text" autocomplete="name" required />
          </div>
          <div class="field">
            <label for="email">Email</label>
            <input id="email" name="email" type="email" autocomplete="email" required />
          </div>
        </div>

        <div class="field">
          <label for="type">Enquiry type</label>
          <select id="type" name="type">
            <option value="Booking">Booking / performance</option>
            <option value="Session">Recording session</option>
            <option value="Collaboration">Collaboration</option>
            <option value="Scoring">Scoring / composition</option>
            <option value="General">General</option>
          </select>
        </div>

        <div class="field">
          <label for="subject">Subject</label>
          <input id="subject" name="subject" type="text" required />
        </div>

        <div class="field">
          <label for="message">Message</label>
          <textarea id="message" name="message" rows="6" required></textarea>
        </div>

        {/* Honeypot — hidden from humans, catches naive bots. */}
        <div class="hp" aria-hidden="true">
          <label for="company">Company (leave blank)</label>
          <input id="company" name="company" type="text" tabindex="-1" autocomplete="off" />
        </div>

        {turnstileKey && <div class="cf-turnstile" data-sitekey={turnstileKey} data-theme="dark" />}

        <button type="submit" class="btn btn-primary form-submit">
          <span class="submit-label">Send message</span>
          <Icon name="arrow-right" size={18} />
        </button>

        <p class="form-status" data-status role="status" aria-live="polite"></p>
      </form>
    </div>
  </section>
</BaseLayout>

<script>
  function initContactForm() {
    const form = document.querySelector<HTMLFormElement>('[data-contact-form]');
    if (!form || form.dataset.bound) return;
    form.dataset.bound = '1';
    const status = form.querySelector<HTMLElement>('[data-status]');
    const submit = form.querySelector<HTMLButtonElement>('.form-submit');
    const label = form.querySelector<HTMLElement>('.submit-label');

    const setStatus = (msg: string, kind: 'success' | 'error' | '') => {
      if (!status) return;
      status.textContent = msg;
      status.dataset.kind = kind;
    };

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      if (!form.checkValidity()) {
        form.reportValidity();
        return;
      }
      submit && (submit.disabled = true);
      label && (label.textContent = 'Sending…');
      setStatus('', '');
      try {
        const res = await fetch(form.action, {
          method: 'POST',
          body: new FormData(form),
          headers: { Accept: 'application/json' },
        });
        if (!res.ok) throw new Error(String(res.status));
        form.reset();
        setStatus("Thanks — your message is on its way. I'll be in touch soon.", 'success');
        label && (label.textContent = 'Sent');
      } catch {
        setStatus(
          'Something went wrong sending that. Please email hello@andylewismusic.com directly.',
          'error'
        );
        submit && (submit.disabled = false);
        label && (label.textContent = 'Send message');
      }
    });
  }
  initContactForm();
  document.addEventListener('astro:after-swap', initContactForm);
</script>

<style>
  .contact-grid {
    display: grid;
    gap: 2.5rem;
  }
  @media (min-width: 900px) {
    .contact-grid {
      grid-template-columns: 0.7fr 1.3fr;
      gap: 4rem;
    }
  }
  .contact-aside {
    display: grid;
    gap: 2.5rem;
    align-content: start;
  }
  .aside-h {
    font-size: var(--text-caption);
    text-transform: uppercase;
    letter-spacing: 0.16em;
    color: var(--color-ink-faint);
    font-weight: 600;
    margin-bottom: 1rem;
  }
  .contact-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 1.1rem;
  }
  .contact-list li {
    display: grid;
    gap: 0.2rem;
  }
  .contact-label {
    font-size: var(--text-caption);
    color: var(--color-ink-faint);
  }
  .contact-list a:hover {
    color: var(--color-accent);
  }

  .contact-form {
    display: grid;
    gap: 1.35rem;
  }
  .field-row {
    display: grid;
    gap: 1.35rem;
  }
  @media (min-width: 560px) {
    .field-row {
      grid-template-columns: 1fr 1fr;
    }
  }
  .field {
    display: grid;
    gap: 0.5rem;
  }
  .field label {
    font-size: var(--text-small);
    font-weight: 500;
    color: var(--color-ink);
  }
  .field input,
  .field select,
  .field textarea {
    width: 100%;
    padding: 0.85em 1em;
    font: inherit;
    font-size: var(--text-small);
    color: var(--color-ink);
    background: var(--color-surface);
    /* Stronger than --color-line-strong to meet WCAG 2.2 non-text contrast
       (1.4.11, ≥3:1) for form-field boundaries. */
    border: 1px solid rgba(244, 242, 238, 0.42);
    border-radius: var(--radius-md);
    transition:
      border-color var(--dur-base) var(--ease-standard),
      box-shadow var(--dur-base) var(--ease-standard);
  }
  .field textarea {
    resize: vertical;
    min-height: 8rem;
  }
  .field input:focus,
  .field select:focus,
  .field textarea:focus {
    outline: none;
    border-color: var(--color-accent);
    box-shadow: 0 0 0 3px var(--color-accent-soft);
  }
  .hp {
    position: absolute;
    left: -9999px;
    width: 1px;
    height: 1px;
    overflow: hidden;
  }
  .form-submit {
    justify-self: start;
  }
  .form-status {
    margin: 0;
    font-size: var(--text-small);
  }
  .form-status[data-kind='success'] {
    color: var(--color-success);
  }
  .form-status[data-kind='error'] {
    color: var(--color-danger);
  }
</style>
