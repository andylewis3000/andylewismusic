---
/**
 * Gear — equipment grouped by category. Hero + section styling from the CMS
 * (Pages → Gear).
 */
import BaseLayout from '@layouts/BaseLayout.astro';
import Section from '@components/layout/Section.astro';
import PageHero from '@components/sections/PageHero.astro';
import GearCard from '@components/cards/GearCard.astro';
import CTASection from '@components/sections/CTASection.astro';
import { getGearByCategory } from '@lib/content';
import { pages, findSection } from '@lib/pages';

const groups = await getGearByCategory();
const p = pages.gear;
const g = findSection(p.sections, 'gear');
const cta = findSection(p.sections, 'cta');
---

<BaseLayout title={p.hero.heading} description={p.hero.intro}>
  <PageHero
    kicker={p.hero.kicker}
    title={p.hero.heading}
    intro={p.hero.intro}
    tone={p.hero.background}
    backgroundImage={p.hero.backgroundImage}
    backgroundAlt={p.hero.backgroundAlt}
    parallax={p.hero.parallax}
  />

  <Section
    tone={g.background}
    backgroundImage={g.backgroundImage}
    backgroundAlt={g.backgroundAlt}
    parallax={g.parallax}
    padding="tight"
    innerClass="gear-sections"
  >
    {
      groups.map((group) => (
        <section class="gear-group" aria-labelledby={`gear-${group.id}`}>
          <h2 id={`gear-${group.id}`} class="gear-heading">
            {group.label}
          </h2>
          <div class="grid-gear">
            {group.items.map((item) => (
              <GearCard item={item} />
            ))}
          </div>
        </section>
      ))
    }
    {groups.length === 0 && <p class="empty">Gear list coming soon.</p>}
  </Section>

  {
    cta.enabled && (
      <CTASection
        tone={cta.background}
        backgroundImage={cta.backgroundImage}
        backgroundAlt={cta.backgroundAlt}
        parallax={cta.parallax}
      />
    )
  }
</BaseLayout>

<style>
  .gear-sections {
    display: grid;
    gap: 3.5rem;
  }
  .gear-heading {
    font-size: var(--text-h3);
    margin-bottom: 1.5rem;
    padding-bottom: 0.75rem;
    border-bottom: 1px solid var(--color-line);
  }
  .grid-gear {
    display: grid;
    gap: 1.5rem;
    grid-template-columns: repeat(auto-fill, minmax(min(100%, 280px), 1fr));
  }
  .empty {
    color: var(--color-ink-muted);
    font-size: var(--text-lead);
  }
</style>
