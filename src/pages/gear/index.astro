---
/**
 * Gear — equipment grouped by category (drums, guitars, studio, …).
 */
import BaseLayout from '@layouts/BaseLayout.astro';
import PageHero from '@components/sections/PageHero.astro';
import GearCard from '@components/cards/GearCard.astro';
import CTASection from '@components/sections/CTASection.astro';
import { getGearByCategory } from '@lib/content';

const groups = await getGearByCategory();
---

<BaseLayout
  title="Gear"
  description="The drums, guitars and studio equipment behind Andy Lewis's sound."
>
  <PageHero
    kicker="Setup"
    title="Gear"
    intro="The instruments and tools behind the sound. Tuned, road-worn and chosen for feel."
  />

  <section class="section-tight">
    <div class="container-page gear-sections">
      {
        groups.map((group) => (
          <section class="gear-group" aria-labelledby={`gear-${group.id}`}>
            <h2 id={`gear-${group.id}`} class="gear-heading">
              {group.label}
            </h2>
            <div class="grid-gear">
              {group.items.map((item) => (
                <GearCard item={item} />
              ))}
            </div>
          </section>
        ))
      }
      {groups.length === 0 && <p class="empty">Gear list coming soon.</p>}
    </div>
  </section>

  <CTASection />
</BaseLayout>

<style>
  .gear-sections {
    display: grid;
    gap: 3.5rem;
  }
  .gear-heading {
    font-size: var(--text-h3);
    margin-bottom: 1.5rem;
    padding-bottom: 0.75rem;
    border-bottom: 1px solid var(--color-line);
  }
  .grid-gear {
    display: grid;
    gap: 1.5rem;
    grid-template-columns: repeat(auto-fill, minmax(min(100%, 280px), 1fr));
  }
  .empty {
    color: var(--color-ink-muted);
    font-size: var(--text-lead);
  }
</style>
