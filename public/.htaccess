# ─────────────────────────────────────────────────────────────────────────
#  Andy Lewis Music — Apache/LiteSpeed config for Hostinger shared hosting
#  Deployed to public_html alongside the static site. Handles HTTPS, caching,
#  compression, security headers and the custom 404.
# ─────────────────────────────────────────────────────────────────────────

# ── Force HTTPS (Hostinger provides the certificate) ───────────────────────
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteCond %{HTTPS} !=on
  RewriteCond %{HTTP:X-Forwarded-Proto} !https
  RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [R=301,L]
</IfModule>

# ── Custom error page ──────────────────────────────────────────────────────
ErrorDocument 404 /404.html

# ── Compression ────────────────────────────────────────────────────────────
<IfModule mod_brotli.c>
  AddOutputFilterByType BROTLI_COMPRESS text/html text/css text/javascript application/javascript application/json image/svg+xml application/xml application/rss+xml
</IfModule>
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css text/javascript application/javascript application/json image/svg+xml application/xml application/rss+xml
</IfModule>

# ── Caching ────────────────────────────────────────────────────────────────
<IfModule mod_headers.c>
  # Fingerprinted build assets never change — cache hard for a year.
  <FilesMatch "\.(?:css|js|woff2|avif|webp|jpg|jpeg|png|gif|svg)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
  # HTML must revalidate so content edits appear promptly.
  <FilesMatch "\.html$">
    Header set Cache-Control "public, max-age=0, must-revalidate"
  </FilesMatch>
  # The search index + feeds: short cache.
  <FilesMatch "\.(?:xml|json)$">
    Header set Cache-Control "public, max-age=3600"
  </FilesMatch>

  # ── Security headers (Best Practices) ──
  Header set X-Content-Type-Options "nosniff"
  Header set Referrer-Policy "strict-origin-when-cross-origin"
  Header set X-Frame-Options "SAMEORIGIN"
  Header set Permissions-Policy "geolocation=(), camera=(), microphone=(), interest-cohort=()"
  Header set Strict-Transport-Security "max-age=31536000; includeSubDomains" "expr=%{HTTPS} == 'on'"
  # Don't leak the CMS admin from referrers etc.
  Header always unset X-Powered-By
</IfModule>

# ── Optional: honour PHP-mailed form (form.php) default handling ────────────
# (No rewrite needed — form.php is requested directly by the contact form.)

# ── Directory listing off ──────────────────────────────────────────────────
Options -Indexes
