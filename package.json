{
  "name": "andylewismusic",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Official website of Andy Lewis — drummer, guitarist & composer. Astro + Sveltia CMS, statically generated for Hostinger.",
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "build": "astro check && astro build && pagefind --site dist",
    "build:fast": "astro build && pagefind --site dist",
    "preview": "astro preview",
    "astro": "astro",
    "check": "astro check",
    "format": "prettier --write \"**/*.{astro,ts,tsx,js,mjs,json,md,mdx,css}\"",
    "lint": "eslint . --ext .js,.mjs,.ts,.tsx,.astro"
  },
  "dependencies": {
    "@astrojs/mdx": "^4.2.0",
    "@astrojs/rss": "^4.0.11",
    "@astrojs/sitemap": "^3.3.0",
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource/special-gothic-condensed-one": "^5.2.3",
    "astro": "^5.7.0",
    "marked": "^18.0.5",
    "motion": "^12.0.0",
    "sharp": "^0.34.0"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.4",
    "@tailwindcss/vite": "^4.1.0",
    "eslint": "^9.20.0",
    "eslint-plugin-astro": "^1.3.1",
    "pagefind": "^1.3.0",
    "prettier": "^3.5.0",
    "prettier-plugin-astro": "^0.14.1",
    "prettier-plugin-tailwindcss": "^0.6.11",
    "tailwindcss": "^4.1.0",
    "typescript": "^5.7.3"
  },
  "engines": {
    "node": ">=20.3.0"
  }
}
