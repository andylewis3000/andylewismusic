# ─────────────────────────────────────────────────────────────
# Andy Lewis Music — environment variables
# Copy to `.env` for local dev. NONE of these are required for a
# basic static build; they configure optional integrations.
# ─────────────────────────────────────────────────────────────

# Public site origin (overrides astro.config `site` if set in CI). Optional.
# PUBLIC_SITE_URL=https://andylewismusic.com

# Cloudflare Turnstile — spam protection for the contact/booking form.
# Site key is public (embedded in HTML); secret key lives ONLY in form.php on Hostinger.
# PUBLIC_TURNSTILE_SITE_KEY=

# Cloudflare Web Analytics token (cookieless, optional).
# PUBLIC_CF_ANALYTICS_TOKEN=

# ── Server-side only (NOT committed; set in Hostinger, used by public_html/form.php) ──
# These are documented here for completeness but are configured on the host, not in Astro.
# TURNSTILE_SECRET_KEY=
# CONTACT_TO_EMAIL=hello@andylewismusic.com
# BOOKING_TO_EMAIL=booking@andylewismusic.com
# SMTP_HOST=
# SMTP_USER=
# SMTP_PASS=
